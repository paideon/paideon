{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@org/source"],
    "paths": {
      "@nexus/types": ["packages/types/src/index.ts"],
      "@nexus/types/*": ["packages/types/src/*"],
      "@nexus/database": ["packages/database/src/index.ts"],
      "@nexus/database/*": ["packages/database/src/*"],
      "@nexus/ui": ["packages/ui/src/index.ts"],
      "@nexus/ui/*": ["packages/ui/src/*"]
    }
  }
}