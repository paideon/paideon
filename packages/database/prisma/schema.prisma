  enrollments TransportEnrollment[]
}

model TransportEnrollment {
  id             String   @id @default(cuid())
  routeId        String
  stopId         String
  studentUserId  String
  schoolId       String
  academicYearId String
  enrolledAt     DateTime @default(now())
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now())

  route        TransportRoute @relation(fields: [routeId], references: [id])
  stop         TransportStop  @relation(fields: [stopId], references: [id])
  student      User           @relation(fields: [studentUserId], references: [id])
  school       School         @relation(fields: [schoolId], references: [id])
  academicYear AcademicYear   @relation(fields: [academicYearId], references: [id])

  @@unique([studentUserId, academicYearId])
}

// =============================================================================
// LAYER 25 — FEE MANAGEMENT
// migration-08-school-life
// =============================================================================

model FeeCategory {
  id          String   @id @default(cuid())
  schoolId    String
  name        String
  description String?
  isRecurring Boolean  @default(false)
  frequency   String?
  createdAt   DateTime @default(now())

  school        School         @relation(fields: [schoolId], references: [id])
  feeStructures FeeStructure[]
}

model FeeStructure {
  id             String    @id @default(cuid())
  feeCategoryId  String
  schoolId       String
  academicYearId String
  grade          Int?
  role           Role?
  amountLKR      Decimal   @db.Decimal(10, 2)
  dueDateFirst   DateTime?
  dueDateSecond  DateTime?
  createdAt      DateTime  @default(now())

  feeCategory  FeeCategory  @relation(fields: [feeCategoryId], references: [id])
  school       School       @relation(fields: [schoolId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  payments FeePayment[]
}

model FeePayment {
  id             String   @id @default(cuid())
  feeStructureId String
  userId         String
  schoolId       String
  academicYearId String
  amountPaidLKR  Decimal  @db.Decimal(10, 2)
  paidAt         DateTime
  paymentMethod  String
  receiptNumber  String
  collectedBy    String?
  notes          String?
  createdAt      DateTime @default(now())

  feeStructure FeeStructure @relation(fields: [feeStructureId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
  school       School       @relation(fields: [schoolId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  @@unique([receiptNumber, schoolId])
}

// =============================================================================
// LAYER 26 — INTERNAL MESSAGING
// migration-08-school-life
// Note: type=ANNOUNCEMENT = interactive admin broadcast (users can reply).
// Distinct from the library Announcement table (read-only notice board).
// =============================================================================

model MessageThread {
  id            String    @id @default(cuid())
  schoolId      String
  subject       String?
  type          String    @default("DIRECT")
  createdBy     String
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  school  School @relation(fields: [schoolId], references: [id])
  creator User   @relation(fields: [createdBy], references: [id])

  participants ThreadParticipant[]
  messages     Message[]
}

model ThreadParticipant {
  id         String    @id @default(cuid())
  threadId   String
  userId     String
  schoolId   String
  lastReadAt DateTime?
  joinedAt   DateTime  @default(now())
  isAdmin    Boolean   @default(false)

  thread MessageThread @relation(fields: [threadId], references: [id])
  user   User          @relation(fields: [userId], references: [id])
  school School        @relation(fields: [schoolId], references: [id])

  @@unique([threadId, userId])
}

model Message {
  id           String    @id @default(cuid())
  threadId     String
  senderUserId String
  schoolId     String
  content      String
  sentAt       DateTime  @default(now())
  editedAt     DateTime?
  deletedAt    DateTime?

  thread MessageThread @relation(fields: [threadId], references: [id])
  sender User          @relation(fields: [senderUserId], references: [id])
  school School        @relation(fields: [schoolId], references: [id])

  attachments MessageAttachment[]
}

model MessageAttachment {
  id        String   @id @default(cuid())
  messageId String
  mediaId   String
  schoolId  String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id])
  media   Media   @relation(fields: [mediaId], references: [id])
  school  School  @relation(fields: [schoolId], references: [id])
}

// =============================================================================
// LAYER 27 — ENGAGEMENT & GAMIFICATION
// migration-09-engagement-analytics
// Raw SQL: chk_badge_tier
// Badge.criteria JSON shapes:
//   { "type": "streak",     "threshold": 30  }
//   { "type": "books_read", "threshold": 10  }
//   { "type": "genres",     "threshold": 5   }
//   { "type": "reviews",    "threshold": 10  }
//   { "type": "downloads",  "threshold": 50  }
//   { "type": "read_mins",  "threshold": 600 }
//   { "type": "manual"                       }
// type:manual = awarded by librarian/admin only. Evaluation job skips these.
// =============================================================================

model UserGamification {
  id                    String    @id @default(cuid())
  userId                String    @unique
  schoolId              String
  currentStreak         Int       @default(0)
  longestStreak         Int       @default(0)
  streakFreezeAvailable Boolean   @default(true)
  lastActivityDate      DateTime?
  totalBooksRead        Int       @default(0)
  totalVaultDownloads   Int       @default(0)
  totalVaultReadMinutes Int       @default(0)
  totalGenresExplored   Int       @default(0)
  totalReviews          Int       @default(0)
  points                Int       @default(0)
  level                 Int       @default(1)
  gradeRank             Int?
  schoolRank            Int?
  optedInLeaderboard    Boolean   @default(true)
  updatedAt             DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  school School @relation(fields: [schoolId], references: [id])

  @@index([schoolId, points])
}

model Badge {
  id          String   @id @default(cuid())
  schoolId    String?
  code        String   @unique
  name        String
  description String
  tier        Int
  iconMediaId String?
  criteria    Json
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  school     School?     @relation(fields: [schoolId], references: [id])
  iconMedia  Media?      @relation(fields: [iconMediaId], references: [id])
  userBadges UserBadge[]
}

model UserBadge {
  id          String   @id @default(cuid())
  userId      String
  badgeId     String
  schoolId    String
  earnedAt    DateTime @default(now())
  triggerData Json?

  user   User   @relation(fields: [userId], references: [id])
  badge  Badge  @relation(fields: [badgeId], references: [id])
  school School @relation(fields: [schoolId], references: [id])

  @@unique([userId, badgeId])
}

// =============================================================================
// LAYER 28 — NOTIFICATIONS
// migration-09-engagement-analytics
// =============================================================================

model Notification {
  id            String              @id @default(cuid())
  schoolId      String
  userId        String
  type          NotificationType
  channel       NotificationChannel
  title         String
  message       String
  actionUrl     String?
  sent          Boolean             @default(false)
  sentAt        DateTime?
  read          Boolean             @default(false)
  readAt        DateTime?
  retryCount    Int                 @default(0)
  lastRetryAt   DateTime?
  failureReason String?
  createdAt     DateTime            @default(now())

  school School @relation(fields: [schoolId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId, read])
  @@index([schoolId, sent])
  @@index([schoolId, type, createdAt])
}

model NotificationPreference {
  id              String           @id @default(cuid())
  userId          String
  schoolId        String
  type            NotificationType
  emailEnabled    Boolean          @default(true)
  whatsappEnabled Boolean          @default(true)
  inAppEnabled    Boolean          @default(true)
  updatedAt       DateTime         @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  school School @relation(fields: [schoolId], references: [id])

  @@unique([userId, type])
}

// =============================================================================
// LAYER 29 — ANALYTICS & CONFIGURATION
// migration-09-engagement-analytics
// =============================================================================

model DailyStatistics {
  id                String   @id @default(cuid())
  schoolId          String
  date              DateTime
  totalCheckouts    Int      @default(0)
  totalReturns      Int      @default(0)
  newReservations   Int      @default(0)
  finesIssuedLKR    Decimal  @default(0) @db.Decimal(10, 2)
  finesCollectedLKR Decimal  @default(0) @db.Decimal(10, 2)
  activeUsers       Int      @default(0)
  newUsers          Int      @default(0)
  vaultDownloads    Int      @default(0)
  vaultViews        Int      @default(0)
  vaultUniqueUsers  Int      @default(0)
  createdAt         DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, date])
}
