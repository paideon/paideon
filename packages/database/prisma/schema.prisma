  user   User             @relation(fields: [userId], references: [id])
  items  VaultShelfItem[]
}

model VaultShelfItem {
  id         String   @id @default(cuid())
  shelfId    String
  resourceId String
  schoolId   String
  addedAt    DateTime @default(now())
  note       String?

  shelf    VaultShelf    @relation(fields: [shelfId], references: [id])
  resource VaultResource @relation(fields: [resourceId], references: [id])
  school   School        @relation(fields: [schoolId], references: [id])

  @@unique([shelfId, resourceId])
}

model VaultSearchAnalytics {
  id              String   @id @default(cuid())
