  deweyDecimal     String?
  description      String?
  coverMediaId     String?
  thumbnailMediaId String?
  edition          String?
  binding          String?
  targetAudience   String?
  ageRange         String?
  seriesName       String?
  volumeNumber     Int?
  donatedBy        String?
  isDonation       Boolean    @default(false)
  tags             String[]
  location         String?
  purchaseDate     DateTime?
  purchasePriceLKR Decimal?   @db.Decimal(10, 2)
  vendor           String?
  status           BookStatus @default(AVAILABLE)
  totalLoans       Int        @default(0)
  popularity       Float      @default(0.0)
  createdBy        String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  deletedAt        DateTime?

  school    School @relation(fields: [schoolId], references: [id])
  cover     Media? @relation("BookCover", fields: [coverMediaId], references: [id])
  thumbnail Media? @relation("BookThumbnail", fields: [thumbnailMediaId], references: [id])

  copies          BookCopy[]
  reservations    Reservation[]
  reviews         Review[]
  bookRequests    BookRequest[]
  bookSuggestions BookSuggestion[]

  @@unique([catalogNumber, schoolId])
  @@unique([isbn13, schoolId])
}

model BookCopy {
  id         String        @id @default(cuid())
  bookId     String
  schoolId   String
  code       String
  condition  BookCondition @default(GOOD)
  status     CopyStatus    @default(AVAILABLE)
  acquiredAt DateTime?
  notes      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  book   Book   @relation(fields: [bookId], references: [id])
  school School @relation(fields: [schoolId], references: [id])

  loans         Loan[]
  damageReports DamageReport[]

  @@unique([code, schoolId])
  @@index([bookId, status])
}

model Loan {
  id                  String         @id @default(cuid())
  schoolId            String
  userId              String
  copyId              String
  checkoutDate        DateTime       @default(now())
  dueDate             DateTime
  returnDate          DateTime?
  status              LoanStatus     @default(ACTIVE)
  renewalCount        Int            @default(0)
  maxRenewals         Int
  checkoutCondition   BookCondition
  returnCondition     BookCondition?
  checkedOutBy        String
  checkedInBy         String?
  overdueNoticeSent   Boolean        @default(false)
  overdueNoticeSentAt DateTime?
  notes               String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  school School   @relation(fields: [schoolId], references: [id])
  user   User     @relation(fields: [userId], references: [id])
  copy   BookCopy @relation(fields: [copyId], references: [id])

  fines          Fine[]
  damageReports  DamageReport[]
  readingHistory ReadingHistory[]

  @@index([schoolId, userId])
  @@index([schoolId, status])
  @@index([schoolId, status, createdAt])
  @@index([dueDate])
  @@index([copyId])
}

model Fine {
  id            String     @id @default(cuid())
  schoolId      String
  userId        String
  loanId        String
  type          FineType
  amountLKR     Decimal    @db.Decimal(10, 2)
  amountPaidLKR Decimal    @default(0) @db.Decimal(10, 2)
  status        FineStatus @default(PENDING)
  daysOverdue   Int?
  dailyRateLKR  Decimal?   @db.Decimal(10, 2)
  paidAt        DateTime?
  paymentMethod String?
  receiptNumber String?
  waivedBy      String?
  waiverReason  String?
  waivedAt      DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  school School @relation(fields: [schoolId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
  loan   Loan   @relation(fields: [loanId], references: [id])

  @@unique([loanId, type])
  @@index([schoolId, userId, status])
  @@index([schoolId, status, createdAt])
}

model Reservation {
  id               String            @id @default(cuid())
