// Default shelves seeded per user after migration-07:
//   "Want to Read" (isDefault: true), "Currently Reading", "Completed"
// Partial unique index (at most one isDefault=true per user) via raw SQL:
//   CREATE UNIQUE INDEX vault_shelf_one_default
//     ON "VaultShelf" ("userId") WHERE "isDefault" = true;
model VaultShelf {
  id        String   @id @default(cuid())
  schoolId  String
  userId    String
  name      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

