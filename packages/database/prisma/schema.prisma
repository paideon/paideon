model Book {
  id               String     @id @default(cuid())
  schoolId         String
  catalogNumber    String?
  isbn13           String?
  isbn10           String?
  title            String
  subtitle         String?
  authors          String[]
  publisher        String?
  publishedDate    String?
  language         String     @default("si")
  pageCount        Int?
  categories       String[]
  subjects         String[]
