// =============================================================================
// LAYER 0 — FOUNDATION
// migration-01-foundation
// =============================================================================

model School {
  id                 String     @id @default(cuid())
  schoolCode         String     @unique
  name               String
  nameShort          String?
  nameSinhala        String?
  nameTamil          String?
  slug               String     @unique
  domain             String?    @unique
  logoMediaId        String?
  type               SchoolType
  medium             String[]
  province           String?
  district           String?
  dsDivision         String?
  gnDivision         String?
  addressId          String?
  phone              String?
  fax                String?
  email              String?
  website            String?
  principalName      String?
  principalEmail     String?
  establishedYear    Int?
  registrationNumber String?
  censusId           String?
  isActive           Boolean    @default(true)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  address Address? @relation(fields: [addressId], references: [id])
  logo    Media?   @relation("SchoolLogo", fields: [logoMediaId], references: [id])

  // Layer 0
  settings           SchoolSettings?
  academicYears      AcademicYear[]
  paideonIdSequences PaideonIdSequence[]

  // Layer 2
  users User[]

  // Layer 3
  studentProfiles   StudentProfile[]
  familyBackgrounds FamilyBackground[]
  residenceHistory  ResidenceHistory[]
  electoralRecords  ElectoralRecord[]
  parentEducation   ParentEducation[]

  // Layer 4
  teacherProfiles TeacherProfile[]
  teacherSubjects TeacherSubject[]
  leaveRecords    LeaveRecord[]

  // Layer 5
  parentProfiles ParentProfile[]

  // Layer 6
  staffProfiles StaffProfile[]

  // Layer 7
  parentStudentLinks ParentStudentLink[]
  emergencyContacts  EmergencyContact[]

  // Layer 8
  studentHealths          StudentHealth[]
  studentHealthConditions StudentHealthCondition[]
  studentVaccinations     StudentVaccination[]

  // Layer 9
  behavioralProfiles BehavioralProfile[]
  counselingSessions CounselingSession[]

  // Layer 11
  media Media[]

  // Layer 12
  buildings        SchoolBuilding[]
  rooms            Room[]
  laboratories     Laboratory[]
  libraryFacility  LibraryFacility?
  sportsFacilities SportsFacility[]
  vehicles         SchoolVehicle[]

  // Layer 13
  subjects         Subject[]
  streams          Stream[]
  classes          Class[]
  classTeachers    ClassTeacher[]
  classEnrollments ClassEnrollment[]

  // Layer 14
  timetablePeriods TimetablePeriod[]
  timetableSlots   TimetableSlot[]

  // Layer 15
  attendance          Attendance[]
  attendanceSummaries AttendanceSummary[]

  // Layer 16
  exams               Exam[]
  examSubjects        ExamSubject[]
  examResults         ExamResult[]
  nationalExamResults NationalExamResult[]

  // Layer 17
  assignments           Assignment[]
  assignmentAttachments AssignmentAttachment[]
  submissions           Submission[]
  submissionAttachments SubmissionAttachment[]
  assignmentComments    AssignmentComment[]

  // Layer 18
  books              Book[]
  bookCopies         BookCopy[]
  loans              Loan[]
  fines              Fine[]
  reservations       Reservation[]
  damageReports      DamageReport[]
  damageReportPhotos DamageReportPhoto[]
  reviews            Review[]
  readingHistory     ReadingHistory[]
  bookRequests       BookRequest[]
  bookSuggestions    BookSuggestion[]
  announcements      Announcement[]
  libraryConfig      LibraryConfig?

  // Layer 19
  vaultResources       VaultResource[]
  vaultReadingProgress VaultReadingProgress[]
  vaultReadingSessions VaultReadingSession[]
  vaultDownloadLogs    VaultDownloadLog[]
  vaultSearchLogs      VaultSearchLog[]
  vaultShelves         VaultShelf[]
  vaultShelfItems      VaultShelfItem[]
  vaultSearchAnalytics VaultSearchAnalytics[]

  // Layer 20
  clubs                    Club[]
  clubMemberships          ClubMembership[]
  clubMeetingRecords       ClubMeetingRecord[]
  clubActivityLogs         ClubActivityLog[]
  clubActivityParticipants ClubActivityParticipant[]
  clubActivityPhotos       ClubActivityPhoto[]

  // Layer 21
  schoolEvents      SchoolEvent[]
  eventParticipants EventParticipant[]
  eventPhotos       EventPhoto[]

  // Layer 22
  disciplinaryRecords   DisciplinaryRecord[]
  disciplinaryActions   DisciplinaryAction[]
  disciplinaryWitnesses DisciplinaryWitness[]

  // Layer 23
  awards          Award[]
  awardRecipients AwardRecipient[]

  // Layer 24
  transportRoutes      TransportRoute[]
  transportStops       TransportStop[]
  transportEnrollments TransportEnrollment[]

  // Layer 25
  feeCategories FeeCategory[]
  feeStructures FeeStructure[]
  feePayments   FeePayment[]

  // Layer 26
  messageThreads     MessageThread[]
  threadParticipants ThreadParticipant[]
  messages           Message[]
  messageAttachments MessageAttachment[]

  // Layer 27
  userGamification UserGamification[]
  badges           Badge[]
  userBadges       UserBadge[]

  // Layer 28
  notifications           Notification[]
  notificationPreferences NotificationPreference[]

  // Layer 29
  dailyStatistics DailyStatistics[]
  qualification   Qualification[]
  serviceRecord   ServiceRecord[]
}

model SchoolSettings {
  id                     String   @id @default(cuid())
  schoolId               String   @unique
  libraryEnabled         Boolean  @default(true)
  vaultEnabled           Boolean  @default(true)
  lmsEnabled             Boolean  @default(false)
  examsEnabled           Boolean  @default(false)
  attendanceEnabled      Boolean  @default(false)
  timetableEnabled       Boolean  @default(false)
  clubsEnabled           Boolean  @default(false)
  transportEnabled       Boolean  @default(false)
  feeManagementEnabled   Boolean  @default(false)
  messagingEnabled       Boolean  @default(true)
  primaryColor           String   @default("#0066CC")
  secondaryColor         String   @default("#004499")
  timezone               String   @default("Asia/Colombo")
  academicYearStartMonth Int      @default(1)
  defaultLanguage        String   @default("si")
  updatedAt              DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id])
}

model AcademicYear {
  id        String   @id @default(cuid())
  schoolId  String
  year      Int
  label     String
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)
  termCount Int      @default(3)
  createdAt DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id])

  classes              Class[]
  classEnrollments     ClassEnrollment[]
  timetablePeriods     TimetablePeriod[]
  timetableSlots       TimetableSlot[]
  attendance           Attendance[]
  attendanceSummaries  AttendanceSummary[]
  exams                Exam[]
  teacherSubjects      TeacherSubject[]
  leaveRecords         LeaveRecord[]
  familyBackgrounds    FamilyBackground[]
  studentHealths       StudentHealth[]
  behavioralProfiles   BehavioralProfile[]
  clubs                Club[]
  clubMemberships      ClubMembership[]
  clubActivityLogs     ClubActivityLog[]
  disciplinaryRecords  DisciplinaryRecord[]
  awardRecipients      AwardRecipient[]
  transportEnrollments TransportEnrollment[]
  feeStructures        FeeStructure[]
  feePayments          FeePayment[]
  schoolEvents         SchoolEvent[]

  @@unique([schoolId, year])
}

model PaideonIdSequence {
  id         String   @id @default(cuid())
  schoolId   String
  role       Role
  lastNumber Int      @default(0)
  updatedAt  DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, role])
}

// =============================================================================
// LAYER 1 — ADDRESSES
// migration-01-foundation
// =============================================================================

model Address {
  id               String   @id @default(cuid())
  line1            String
  line2            String?
  village          String?
  gnDivision       String?
  gnDivisionNumber String?
  dsDivision       String?
  city             String?
  district         String?
  province         String?
  postalCode       String?
  country          String   @default("LK")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  schools            School[]
  studentProfiles    StudentProfile[]
  teacherProfiles    TeacherProfile[]
  parentProfilesHome ParentProfile[]    @relation("ParentHomeAddress")
  parentProfilesWork ParentProfile[]    @relation("ParentWorkAddress")
  staffProfiles      StaffProfile[]
  emergencyContacts  EmergencyContact[]
  transportStops     TransportStop[]
}

// =============================================================================
// LAYER 2 — IDENTITY & AUTH
// migration-01-foundation
// Raw SQL: chk_user_role, chk_user_status
// =============================================================================

model User {
  id                String     @id @default(cuid())
  schoolId          String
  paideonId         String     @unique
  email             String
  emailVerified     Boolean    @default(false)
  password          String?
  role              Role
  status            UserStatus @default(PENDING)
  firstName         String
  lastName          String
  displayName       String?
  profileImageId    String?
  phone             String?
  whatsappNumber    String?
  cardNumber        String     @unique
  cardQrCode        String?
  totpSecret        String? // encrypted - never expose in API responses
  totpEnabled       Boolean    @default(false)
  lastLoginAt       DateTime?
  passwordChangedAt DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  deletedAt         DateTime?

  school       School @relation(fields: [schoolId], references: [id])
  profileImage Media? @relation("UserProfileImage", fields: [profileImageId], references: [id])

  // Profiles (at most one per role)
  studentProfile StudentProfile?
  teacherProfile TeacherProfile?
  parentProfile  ParentProfile?
  staffProfile   StaffProfile?

  // Security
  refreshTokens           RefreshToken[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  totpBackupCodes         TotpBackupCode[]

  // Family
  parentLinks       ParentStudentLink[] @relation("ParentLinks")
  studentLinks      ParentStudentLink[] @relation("StudentLinks")
  emergencyContacts EmergencyContact[]

  // Layer 3 — student data (FK to User.id)
  familyBackgrounds FamilyBackground[]
  residenceHistory  ResidenceHistory[]
  electoralRecords  ElectoralRecord[]
  parentEducation   ParentEducation[]

  // Layer 4 — teacher data (FK to User.id)
  qualifications  Qualification[]
  teacherSubjects TeacherSubject[]
  leaveRecords    LeaveRecord[]

  // Layer 8
  studentHealths   StudentHealth[]
  healthConditions StudentHealthCondition[]
  vaccinations     StudentVaccination[]

  // Layer 9
  behavioralProfiles          BehavioralProfile[]
  counselingSessions          CounselingSession[] @relation("StudentCounselingSessions")
  conductedCounselingSessions CounselingSession[] @relation("CounselorSessions")

  // Academic
  classTeacherAssignments ClassTeacher[]
  classEnrollments        ClassEnrollment[]
  timetableSlots          TimetableSlot[]
  attendance              Attendance[]
  attendanceSummaries     AttendanceSummary[]
  examResults             ExamResult[]
  nationalExamResults     NationalExamResult[]
  assignmentsCreated      Assignment[]
  submissions             Submission[]
  assignmentComments      AssignmentComment[]

  // Library
  loans           Loan[]
  fines           Fine[]
  reservations    Reservation[]
  reviews         Review[]
  readingHistory  ReadingHistory[]
  bookRequests    BookRequest[]
  bookSuggestions BookSuggestion[]

  // Vault
  vaultReadingProgress VaultReadingProgress[]
  vaultReadingSessions VaultReadingSession[]
  vaultDownloadLogs    VaultDownloadLog[]
  vaultSearchLogs      VaultSearchLog[]
  vaultShelves         VaultShelf[]

  // School life
  clubMemberships      ClubMembership[]
  clubsInCharge        Club[]
  eventParticipations  EventParticipant[]
  disciplinaryRecords  DisciplinaryRecord[]
  disciplinaryWitness  DisciplinaryWitness[]
  awardRecipients      AwardRecipient[]
  transportEnrollments TransportEnrollment[]
  vehiclesAssigned     SchoolVehicle[]
  driverRoutes         TransportRoute[]
  feePayments          FeePayment[]

  // Messaging
  messageThreadsCreated MessageThread[]
  threadParticipations  ThreadParticipant[]
  messagesSent          Message[]

  // Engagement
  gamification      UserGamification?
  userBadges        UserBadge[]
  notifications     Notification[]
  notificationPrefs NotificationPreference[]

  // Media
  mediaUploaded           Media[]                   @relation("MediaUploadedBy")
  ServiceRecord           ServiceRecord[]
  ClubActivityParticipant ClubActivityParticipant[]

  @@unique([email, schoolId])
  @@index([schoolId, role, status])
  @@index([schoolId, deletedAt])
}

// =============================================================================
// LAYER 3 — STUDENT DOMAIN
// migration-02-profiles
// Raw SQL: chk_current_grade, chk_admission_grade
// =============================================================================

model StudentProfile {
  id                      String              @id @default(cuid())
  userId                  String              @unique
  schoolId                String
  admissionNumber         String
  dateOfBirth             DateTime
  gender                  Gender
  nationality             String              @default("Sri Lankan")
  nicNumber               String?
  religion                String?
  ethnicity               String?
  medium                  MediumOfInstruction
  homeAddressId           String?
  currentGrade            Int
  currentSection          String?
  streamId                String?
  admissionDate           DateTime
  gradeAtAdmission        Int
  previousSchool          String?
  previousSchoolDistrict  String?
  isTransferStudent       Boolean             @default(false)
  olIndexNumber           String?
  olYear                  Int?
  alIndexNumber           String?
  alYear                  Int?
  grade5ScholarshipYear   Int?
  grade5ScholarshipResult String?
  bloodGroup              String?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  user        User     @relation(fields: [userId], references: [id])
  school      School   @relation(fields: [schoolId], references: [id])
  homeAddress Address? @relation(fields: [homeAddressId], references: [id])
  stream      Stream?  @relation(fields: [streamId], references: [id])

  // Child models FK to User.id, not StudentProfile.id.
  // Their reverse relations live on User, not here.

  @@unique([admissionNumber, schoolId])
}

model FamilyBackground {
  id                        String         @id @default(cuid())
  studentUserId             String
  schoolId                  String
  academicYearId            String
  familySize                Int?
  childPositionInFamily     Int?
  totalSiblings             Int?
  householdRooms            Int?
  homeOwnership             HomeOwnership?
  studyFacilitiesAtHome     String[]
  languagesSpokenAtHome     String[]
  householdMonthlyIncomeLKR Int?
  fatherOccupation          String?
  motherOccupation          String?
  guardianOccupation        String?
  receivesScholarship       Boolean        @default(false)
  scholarshipType           String?
  freeMealEligible          Boolean        @default(false)
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt

  student      User         @relation(fields: [studentUserId], references: [id])
  school       School       @relation(fields: [schoolId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  @@unique([studentUserId, academicYearId])
}

model ResidenceHistory {
  id              String   @id @default(cuid())
  studentUserId   String
  schoolId        String
  city            String
  district        String?
  yearFrom        Int
  yearTo          Int?
  reasonForMoving String?
  createdAt       DateTime @default(now())

  student User   @relation(fields: [studentUserId], references: [id])
  school  School @relation(fields: [schoolId], references: [id])
}

model ElectoralRecord {
  id                 String   @id @default(cuid())
  studentUserId      String
  schoolId           String
  parentRelationship String
  electoralYear      Int
  electoralDistrict  String
  pollingDivision    String
  gnDivision         String
  street             String
  householdNumber    String
  serialNumber       String
  createdAt          DateTime @default(now())

  student User   @relation(fields: [studentUserId], references: [id])
  school  School @relation(fields: [schoolId], references: [id])
}

model ParentEducation {
  id                   String   @id @default(cuid())
  studentUserId        String
  schoolId             String
  parentRelationship   String
  highestQualification String
  fieldOfStudy         String?
  institution          String?
  yearCompleted        Int?
  createdAt            DateTime @default(now())

  student User   @relation(fields: [studentUserId], references: [id])
  school  School @relation(fields: [schoolId], references: [id])
}

// =============================================================================
// LAYER 4 — TEACHER DOMAIN
// migration-02-profiles
// =============================================================================

model TeacherProfile {
  id                           String              @id @default(cuid())
  userId                       String              @unique
  schoolId                     String
  employeeId                   String
  dateOfBirth                  DateTime
  gender                       Gender
  nicNumber                    String
  passportNumber               String?
  religion                     String?
  ethnicity                    String?
  medium                       MediumOfInstruction
  homeAddressId                String?
  residentialDistrict          String?
  distanceFromSchoolKm         Float?
  department                   String?
  designation                  String?
  employmentType               EmploymentType
  recruitmentMethod            String?
  appointmentDate              DateTime
  currentSchoolAppointmentDate DateTime
  confirmationStatus           String
  confirmationDate             DateTime?
  probationExtensionReason     String?
  salaryGrade                  String?
  basicSalaryLKR               Int?
  salaryIncrementDate          DateTime?
  wopPensionNumber             String?
  pspfNumber                   String?
  sinhalaReading               LanguageProficiency @default(AVERAGE)
  sinhalaWriting               LanguageProficiency @default(AVERAGE)
  sinhalaSpeaking              LanguageProficiency @default(AVERAGE)
  tamilReading                 LanguageProficiency @default(AVERAGE)
  tamilWriting                 LanguageProficiency @default(AVERAGE)
  tamilSpeaking                LanguageProficiency @default(AVERAGE)
  englishReading               LanguageProficiency @default(AVERAGE)
  englishWriting               LanguageProficiency @default(AVERAGE)
  englishSpeaking              LanguageProficiency @default(AVERAGE)
  isClassTeacher               Boolean             @default(false)
  createdAt                    DateTime            @default(now())
  updatedAt                    DateTime            @updatedAt

  user        User     @relation(fields: [userId], references: [id])
  school      School   @relation(fields: [schoolId], references: [id])
  homeAddress Address? @relation(fields: [homeAddressId], references: [id])

  @@unique([employeeId, schoolId])
}

model Qualification {
  id                 String            @id @default(cuid())
  teacherUserId      String
  schoolId           String
  type               QualificationType
  title              String
  fieldOfStudy       String?
  institution        String
  country            String            @default("LK")
  yearCompleted      Int?
  grade              String?
  olIndexNumber      String?
  alIndexNumber      String?
  certificateMediaId String?
  createdAt          DateTime          @default(now())

  teacher          User   @relation(fields: [teacherUserId], references: [id])
  school           School @relation(fields: [schoolId], references: [id])
  certificateMedia Media? @relation(fields: [certificateMediaId], references: [id])
}

model ServiceRecord {
  id               String    @id @default(cuid())
  teacherUserId    String
  schoolId         String
  institutionName  String
  institutionType  String?
  district         String?
  province         String?
  postHeld         String
  department       String?
  dateArrived      DateTime
  dateDeparted     DateTime?
  transferType     String?
  transferReason   String?
  isCurrentPosting Boolean   @default(false)
  createdAt        DateTime  @default(now())

  teacher User   @relation(fields: [teacherUserId], references: [id])
  school  School @relation(fields: [schoolId], references: [id])
}

model TeacherSubject {
  id                 String   @id @default(cuid())
  teacherUserId      String
  schoolId           String
  subjectId          String
  academicYearId     String
  gradeLevel         String?
  isAppointedSubject Boolean  @default(true)
  createdAt          DateTime @default(now())

  teacher      User         @relation(fields: [teacherUserId], references: [id])
  school       School       @relation(fields: [schoolId], references: [id])
  subject      Subject      @relation(fields: [subjectId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  @@unique([teacherUserId, subjectId, academicYearId, gradeLevel])
}

// Covers both TEACHER and STAFF leave. staffType discriminates ("TEACHER"|"STAFF").
model LeaveRecord {
  id                   String      @id @default(cuid())
  userId               String
  schoolId             String
  academicYearId       String
  staffType            String
  type                 LeaveType
  startDate            DateTime
  endDate              DateTime
  daysCount            Int
  reason               String?
  approvedBy           String?
  approvedAt           DateTime?
  status               LeaveStatus @default(PENDING)
  medicalCertificateId String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  user               User         @relation(fields: [userId], references: [id])
  school             School       @relation(fields: [schoolId], references: [id])
  academicYear       AcademicYear @relation(fields: [academicYearId], references: [id])
  medicalCertificate Media?       @relation(fields: [medicalCertificateId], references: [id])
}

