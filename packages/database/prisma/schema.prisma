// =============================================================================
// Paideon — schema.prisma
// Version: 5.0
// Database: PostgreSQL 16
// Tables: 107
// Source: docs/database/schema_design_v5.md
//
// Raw SQL blocks (partial indexes + CHECK constraints) live in:
//   packages/database/prisma/sql/
//   Each file is named after the migration it belongs to.
//
// FIXES vs first draft:
//   - ThreadParticipant: removed stray `Thread` keyword on relation field
//   - StudentHealth / StudentHealthCondition / StudentVaccination /
//     BehavioralProfile / CounselingSession: removed dual-@relation on
//     studentUserId (Prisma forbids two @relation on the same scalar)
//   - StudentProfile: removed reverse relations that don't belong here
//     (those models FK to User.id, not StudentProfile.id)
//   - User: added missing reverses (familyBackgrounds, residenceHistory,
//     electoralRecords, parentEducation, qualifications, studentHealths,
//     healthConditions, vaccinations, behavioralProfiles, attendanceSummaries,
//     examResults, nationalExamResults, driverRoutes)
//   - School: added all missing reverse relations for prisma validate
//   - User.studentProfile / qualifications: removed bogus TeacherProfile?
//     relation aliases; studentProfile now correctly typed as StudentProfile?
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMERATIONS
// =============================================================================

